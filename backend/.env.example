# Copy to .env and fill in. Master copies live in ~/.env (THISISEVEN_*).

# Postgres password for the `even` role (app + gotrue share the container).
EVEN_DB_PASSWORD=

# HS256 secret GoTrue signs access tokens with; evend verifies with the same.
# Source: THISISEVEN_GOTRUE_JWT_SECRET in ~/.env (openssl rand -hex 32).
GOTRUE_JWT_SECRET=
