# Copy to .env and fill in. Master copies live in ~/.env (THISISEVEN_*).

# Postgres password for the `even` role (app + gotrue share the container).
EVEN_DB_PASSWORD=

# HS256 secret GoTrue signs access tokens with; evend verifies with the same.
# Source: THISISEVEN_GOTRUE_JWT_SECRET in ~/.env (openssl rand -hex 32).
GOTRUE_JWT_SECRET=

# Google integration (Gmail discovery + Calendar writes). Desktop OAuth client
# from GCP project (consent screen in testing mode, house.marcansu@gmail.com
# as test user). Master copies: GOOGLE_OAUTH_CLIENT_ID/SECRET in ~/.env.
# Leave empty to disable the Google feature entirely.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# iOS OAuth client (in-app PKCE connect; no secret)
GOOGLE_IOS_CLIENT_ID=
